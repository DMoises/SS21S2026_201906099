    MONTH(CAST(FechaTransaccion AS DATE)) AS Mes,
    DAY(CAST(FechaTransaccion AS DATE)) AS Dia
FROM dbo.TransaccionesVenta 
WHERE FechaTransaccion IS NOT NULL;</property>
